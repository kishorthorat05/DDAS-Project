# DDAS Environment Configuration

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production-use-secrets-token-hex-32-for-security
JWT_SECRET=change-jwt-secret-too-use-a-long-random-string

# Google Generative AI
# Get your key at https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyAM-kaySbPdT-ig7cK0YCzIWfiwX5mXTug
GOOGLE_MODEL=gemini-2.5-flash

# Monitoring
MONITORED_DIR=downloads

# Database (SQLite default — change to postgresql://user:pass@host/db for Postgres)
