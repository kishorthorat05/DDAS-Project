# ─── DDAS Environment Configuration ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Flask
FLASK_ENV=development
SECRET_KEY=replace-with-a-long-random-string-secrets-token-hex-32
JWT_SECRET=replace-with-another-long-random-string

# Google Generative AI
# Get your key at https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyC5lT3jycngMJj-twwHte_iXKrlniAY6hw
GOOGLE_MODEL=gemini-1.5-flash

# Monitoring
MONITORED_DIR=/path/to/your/downloads/folder

# Database (SQLite default — change to postgresql://user:pass@host/db for Postgres)
DATABASE_URL=sqlite:///data/ddas.db

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Upload limits
# MAX_FILE_SIZE_MB=200

# Production only
# SESSION_COOKIE_SECURE=true
